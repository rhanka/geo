# Build context pruning for the geo-api image. node_modules and dist are
# rebuilt inside the image (npm ci + npm run build), so never ship the host's.

# Dependencies (reinstalled via `npm ci` against the committed lockfile)
node_modules
**/node_modules
.npm

# Build output (regenerated by `npm run build`)
dist
**/dist
build
**/build
.svelte-kit
**/.svelte-kit
*.tsbuildinfo

# Acquisition cache & large raw downloads (re-downloadable, never needed at build)
.cache
data/raw
data/tmp
data/normalized
data/requests
*.zip
*.gpkg
*.gdb
*.shp
*.shx
*.dbf
*.prj

# VCS, CI, docs, editor & coordination cruft
.git
.gitignore
.github
docs
coverage
.h2a
*.log
.DS_Store

# Env & secrets
.env
.env.*

# Docker / deploy artifacts not needed inside the image
Dockerfile
.dockerignore
deploy/k8s
