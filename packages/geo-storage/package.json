{
  "name": "@sentropic/geo-storage",
  "version": "0.1.0",
  "type": "module",
  "description": "Abstraction de stockage des données normalisées : Store (get/put/list/has) avec FsStore (local) et S3Store (Scaleway Object Storage / S3). ADR-0012.",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "git+https://github.com/rhanka/geo.git", "directory": "packages/geo-storage" },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@sentropic/geo-core": "^0.1.0",
    "@aws-sdk/client-s3": "^3.700.0"
  }
}
