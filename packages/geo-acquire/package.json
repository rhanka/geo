{
  "name": "@sentropic/geo-acquire",
  "version": "0.1.0",
  "type": "module",
  "description": "Moteur d'acquisition de données géographiques : download, gate licence, cache + checksum, normalisation vers @sentropic/geo-core.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/geo.git",
    "directory": "packages/geo-acquire"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@sentropic/geo-core": "^0.1.0"
  },
  "devDependencies": {
    "proj4": "^2.20.9",
    "@types/proj4": "^2.5.6",
    "@sentropic/geo-storage": "^0.1.0"
  }
}
