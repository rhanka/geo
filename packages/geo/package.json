{
  "name": "@sentropic/geo",
  "version": "0.1.0",
  "type": "module",
  "description": "Moteur Node @sentropic/geo : acquisition (download/GDAL/CSV/arcgis) + stockage (S3/fs, ADR-0012) + API OGC API – Features + CLI `geo`. Fusionne geo-acquire+geo-storage+geo-sources+geo-api+geo-cli (ADR-0017).",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/geo.git",
    "directory": "packages/geo"
  },
  "sideEffects": false,
  "bin": {
    "geo": "./dist/cli/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./acquire": {
      "types": "./dist/acquire/index.d.ts",
      "import": "./dist/acquire/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@sentropic/geo-core": "^0.1.0",
    "@aws-sdk/client-s3": "^3.700.0"
  },
  "devDependencies": {
    "proj4": "^2.20.9",
    "@types/proj4": "^2.5.6"
  }
}
