{
  "name": "@sentropic/geo",
  "version": "0.3.0",
  "type": "module",
  "description": "Moteur Node @sentropic/geo : acquisition (download/GDAL/CSV/arcgis) + stockage (S3/fs, ADR-0012) + API OGC API – Features + CLI `geo`. Fusionne geo-acquire+geo-storage+geo-sources+geo-api+geo-cli (ADR-0017).",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/geo.git",
    "directory": "packages/geo"
  },
  "sideEffects": false,
  "bin": {
    "geo": "dist/cli/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./acquire": {
      "types": "./dist/acquire/index.d.ts",
      "import": "./dist/acquire/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./api/app": {
      "types": "./dist/api/app.d.ts",
      "import": "./dist/api/app.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "import": "./dist/catalog/index.js"
    },
    "./normalize": {
      "types": "./dist/normalize/index.d.ts",
      "import": "./dist/normalize/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "start": "node dist/api/server.js",
    "cli": "tsx src/cli/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@hono/node-server": "^2.0.4",
    "@sentropic/geo-core": "^0.3.0",
    "commander": "^15.0.0",
    "hono": "^4.12.25",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "@types/proj4": "^2.5.6",
    "proj4": "^2.20.9"
  }
}
