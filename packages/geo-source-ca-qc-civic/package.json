    "directory": "packages/geo-source-ca-qc-civic"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests"
  },
  "dependencies": {
    "@sentropic/geo-core": "^0.1.0",
    "@sentropic/geo": "^0.1.0"
  }
